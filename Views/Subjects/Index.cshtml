@model IEnumerable<TeacherWorkplace.Models.Subject>
@{ ViewData["Title"] = "Дисциплины"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-book me-2 text-warning"></i>Дисциплины</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Добавить дисциплину</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr><th>Код</th><th>Название</th><th>Семестр</th><th>Часов</th><th>Описание</th><th style="width:120px"></th></tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@(s.Code ?? "—")</span></td>
                            <td class="fw-semibold">@s.Name</td>
                            <td class="text-center">@s.Semester</td>
                            <td class="text-center">@s.TotalHours ч.</td>
                            <td class="text-muted small">@(s.Description ?? "—")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-warning me-1"><i class="fas fa-edit"></i></a>
                                <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
