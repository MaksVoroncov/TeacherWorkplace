@{
    ViewData["Title"] = "Отчёты";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-chart-bar me-2 text-primary"></i>Отчёты</h2>
</div>

<div class="row g-4">

    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center py-5">
                <div class="mb-3">
                    <i class="fas fa-graduation-cap fa-4x text-primary opacity-75"></i>
                </div>
                <h4 class="card-title fw-bold">Отчёт по успеваемости</h4>
                <p class="text-muted">Средний балл студентов, распределение оценок, рейтинг по группе</p>
                <a asp-controller="Reports" asp-action="Performance" class="btn btn-primary mt-2">
                    <i class="fas fa-chart-line me-1"></i> Открыть отчёт
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center py-5">
                <div class="mb-3">
                    <i class="fas fa-clipboard-check fa-4x text-success opacity-75"></i>
                </div>
                <h4 class="card-title fw-bold">Отчёт по посещаемости</h4>
                <p class="text-muted">Процент присутствия, пропуски, статистика по студентам за период</p>
                <a asp-controller="Reports" asp-action="Attendance" class="btn btn-success mt-2">
                    <i class="fas fa-calendar-check me-1"></i> Открыть отчёт
                </a>
            </div>
        </div>
    </div>

</div>
