@{
    ViewData["Title"] = "Отметить посещаемость";

    var students = ViewBag.Students as List<TeacherWorkplace.Models.Student>;
    var existing = ViewBag.ExistingAttendance as List<TeacherWorkplace.Models.Attendance>;
    int? selSubjectId = ViewBag.SelectedSubjectId;
    int? selGroupId   = ViewBag.SelectedGroupId;

    // Helper: get existing status for a student
    TeacherWorkplace.Models.AttendanceStatus? GetStatus(int studentId)
    {
        return existing?.FirstOrDefault(a => a.StudentId == studentId)?.Status;
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-clipboard-check me-2 text-primary"></i>Отметить посещаемость</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Назад к журналу
    </a>
</div>

@* ── Шаг 1: выбор дисциплины и группы ─────────────────────────────────────── *@
<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-sliders-h me-2"></i> Шаг 1 — Выберите дисциплину и группу
    </div>
    <div class="card-body">
        <form method="get" asp-action="TakeAttendance" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold">Дисциплина</label>
                <select name="subjectId" class="form-select" required>
                    <option value="">— Выберите дисциплину —</option>
                    @foreach (SelectListItem item in (IEnumerable<SelectListItem>)ViewBag.Subjects)
                    {
                        <option value="@item.Value"
                                selected="@(item.Value == selSubjectId?.ToString())">
                            @item.Text
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label fw-semibold">Учебная группа</label>
                <select name="groupId" class="form-select" required>
                    <option value="">— Выберите группу —</option>
                    @foreach (SelectListItem item in (IEnumerable<SelectListItem>)ViewBag.Groups)
                    {
                        <option value="@item.Value"
                                selected="@(item.Value == selGroupId?.ToString())">
                            @item.Text
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-users me-1"></i> Загрузить
                </button>
            </div>
        </form>
    </div>
</div>

@* ── Шаг 2: список студентов для отметки ───────────────────────────────────── *@
@if (students != null && selSubjectId.HasValue && selGroupId.HasValue)
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>
                <i class="fas fa-user-check me-2"></i>
                Шаг 2 — Отметьте присутствие
                <span class="badge bg-light text-dark ms-2">@DateTime.Today.ToString("dd.MM.yyyy")</span>
            </span>
            <div class="d-flex gap-2">
                <button type="button" id="btnAllPresent" class="btn btn-sm btn-success">
                    <i class="fas fa-check-double me-1"></i> Все присутствуют
                </button>
                <button type="button" id="btnAllAbsent" class="btn btn-sm btn-outline-danger">
                    <i class="fas fa-times me-1"></i> Все отсутствуют
                </button>
            </div>
        </div>
        <div class="card-body">
            @if (!students.Any())
            {
                <div class="text-center py-4 text-muted">
                    <i class="fas fa-user-slash fa-3x mb-3 d-block opacity-25"></i>
                    <h6>В выбранной группе нет студентов</h6>
                </div>
            }
            else
            {
                <form asp-action="SaveAttendance" method="post" id="attendanceForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="subjectId" value="@selSubjectId" />
                    <input type="hidden" name="groupId"   value="@selGroupId" />

                    @* Легенда статусов *@
                    <div class="mb-3 p-3 bg-light rounded border">
                        <span class="fw-semibold me-3">Статусы:</span>
                        <span class="badge bg-success me-2"><i class="fas fa-check me-1"></i>Присутствует</span>
                        <span class="badge bg-danger me-2"><i class="fas fa-times me-1"></i>Отсутствует</span>
                        <span class="badge bg-warning text-dark me-2"><i class="fas fa-clock me-1"></i>Опоздал</span>
                        <span class="badge bg-info text-dark"><i class="fas fa-file-alt me-1"></i>Уваж. причина</span>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle" id="attendanceTable">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:40px">#</th>
                                    <th><i class="fas fa-user me-1"></i>Студент</th>
                                    <th class="text-center" style="width:160px">Статус</th>
                                    <th class="text-center" style="width:120px">
                                        <span class="badge bg-success"><i class="fas fa-check"></i> Присутствует</span>
                                    </th>
                                    <th class="text-center" style="width:120px">
                                        <span class="badge bg-warning text-dark"><i class="fas fa-clock"></i> Опоздал</span>
                                    </th>
                                    <th class="text-center" style="width:130px">
                                        <span class="badge bg-info text-dark"><i class="fas fa-file-alt"></i> Уваж. прич.</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int rowNum = 1; }
                                @foreach (var student in students)
                                {
                                    var current = GetStatus(student.Id);
                                    // Default: if existing => use it; if no records yet => Present
                                    var defaultStatus = current ?? (existing != null && existing.Any() ? TeacherWorkplace.Models.AttendanceStatus.Absent : TeacherWorkplace.Models.AttendanceStatus.Present);
                                    bool isPresent = defaultStatus == TeacherWorkplace.Models.AttendanceStatus.Present;
                                    bool isAbsent  = defaultStatus == TeacherWorkplace.Models.AttendanceStatus.Absent;
                                    bool isLate    = defaultStatus == TeacherWorkplace.Models.AttendanceStatus.Late;
                                    bool isExcused = defaultStatus == TeacherWorkplace.Models.AttendanceStatus.Excused;

                                    <tr id="row-@student.Id" class="@(isAbsent ? "table-danger" : isLate ? "table-warning" : isExcused ? "table-info" : "")">
                                        <td class="text-muted">@rowNum</td>
                                        <td>
                                            <div class="fw-semibold">@student.FullName</div>
                                            <small class="text-muted">@student.Group?.Name</small>
                                        </td>
                                        <td class="text-center">
                                            <span id="badge-@student.Id" class="badge @(isPresent ? "bg-success" : isLate ? "bg-warning text-dark" : isExcused ? "bg-info text-dark" : "bg-danger")">
                                                @(isPresent ? "Присутствует" : isLate ? "Опоздал" : isExcused ? "Уваж. причина" : "Отсутствует")
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <input type="checkbox"
                                                   class="form-check-input status-check"
                                                   name="presentStudents"
                                                   value="@student.Id"
                                                   data-student="@student.Id"
                                                   data-type="present"
                                                   @(isPresent ? "checked" : "")
                                                   style="width:1.3em;height:1.3em;cursor:pointer;" />
                                        </td>
                                        <td class="text-center">
                                            <input type="checkbox"
                                                   class="form-check-input status-check"
                                                   name="lateStudents"
                                                   value="@student.Id"
                                                   data-student="@student.Id"
                                                   data-type="late"
                                                   @(isLate ? "checked" : "")
                                                   style="width:1.3em;height:1.3em;cursor:pointer;" />
                                        </td>
                                        <td class="text-center">
                                            <input type="checkbox"
                                                   class="form-check-input status-check"
                                                   name="excusedStudents"
                                                   value="@student.Id"
                                                   data-student="@student.Id"
                                                   data-type="excused"
                                                   @(isExcused ? "checked" : "")
                                                   style="width:1.3em;height:1.3em;cursor:pointer;" />
                                        </td>
                                    </tr>
                                    rowNum++;
                                }
                            </tbody>
                        </table>
                    </div>

                    @* Итоги перед сохранением *@
                    <div class="mt-3 p-3 bg-light rounded border d-flex gap-4 align-items-center flex-wrap">
                        <span class="fw-semibold">Итого:</span>
                        <span class="text-success fw-bold"><i class="fas fa-check me-1"></i>Присутствуют: <span id="countPresent">0</span></span>
                        <span class="text-danger fw-bold"><i class="fas fa-times me-1"></i>Отсутствуют: <span id="countAbsent">0</span></span>
                        <span class="text-warning fw-bold"><i class="fas fa-clock me-1"></i>Опоздали: <span id="countLate">0</span></span>
                        <span class="text-info fw-bold"><i class="fas fa-file-alt me-1"></i>Уваж. прич.: <span id="countExcused">0</span></span>
                        <div class="ms-auto">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-save me-2"></i>Сохранить посещаемость
                            </button>
                        </div>
                    </div>
                </form>
            }
        </div>
    </div>
}

@section Scripts {
<script>
(function () {
    // ── Счётчики ──────────────────────────────────────────────────────────────
    function updateCounts() {
        var rows = document.querySelectorAll('#attendanceTable tbody tr');
        var present = 0, absent = 0, late = 0, excused = 0;
        rows.forEach(function(row) {
            var sid = row.id.replace('row-', '');
            var chkP = document.querySelector('input[name="presentStudents"][value="' + sid + '"]');
            var chkL = document.querySelector('input[name="lateStudents"][value="' + sid + '"]');
            var chkE = document.querySelector('input[name="excusedStudents"][value="' + sid + '"]');
            if (chkP && chkP.checked)      present++;
            else if (chkL && chkL.checked) late++;
            else if (chkE && chkE.checked) excused++;
            else                           absent++;
        });
        document.getElementById('countPresent').textContent = present;
        document.getElementById('countAbsent').textContent  = absent;
        document.getElementById('countLate').textContent    = late;
        document.getElementById('countExcused').textContent = excused;
    }

    // ── Обновление строки при смене чекбокса ─────────────────────────────────
    function updateRow(studentId) {
        var chkP = document.querySelector('input[name="presentStudents"][value="' + studentId + '"]');
        var chkL = document.querySelector('input[name="lateStudents"][value="'   + studentId + '"]');
        var chkE = document.querySelector('input[name="excusedStudents"][value="'+ studentId + '"]');
        var row   = document.getElementById('row-'   + studentId);
        var badge = document.getElementById('badge-' + studentId);

        // Взаимоисключение: только один статус активен
        // (handled below in click handler — here just read current state)
        var isP = chkP && chkP.checked;
        var isL = chkL && chkL.checked;
        var isE = chkE && chkE.checked;

        row.classList.remove('table-danger', 'table-warning', 'table-info');
        badge.classList.remove('bg-success', 'bg-danger', 'bg-warning', 'bg-info', 'text-dark');

        if (isP) {
            badge.className = 'badge bg-success';
            badge.textContent = 'Присутствует';
        } else if (isL) {
            badge.className = 'badge bg-warning text-dark';
            badge.textContent = 'Опоздал';
            row.classList.add('table-warning');
        } else if (isE) {
            badge.className = 'badge bg-info text-dark';
            badge.textContent = 'Уваж. причина';
            row.classList.add('table-info');
        } else {
            badge.className = 'badge bg-danger';
            badge.textContent = 'Отсутствует';
            row.classList.add('table-danger');
        }
    }

    // ── Клик по чекбоксу ─────────────────────────────────────────────────────
    document.querySelectorAll('.status-check').forEach(function(chk) {
        chk.addEventListener('change', function() {
            var sid  = this.dataset.student;
            var type = this.dataset.type;

            // Если ставим галочку — снимаем остальные два
            if (this.checked) {
                var others = ['present', 'late', 'excused'].filter(function(t) { return t !== type; });
                others.forEach(function(t) {
                    var names = { present: 'presentStudents', late: 'lateStudents', excused: 'excusedStudents' };
                    var el = document.querySelector('input[name="' + names[t] + '"][value="' + sid + '"]');
                    if (el) el.checked = false;
                });
            }
            updateRow(sid);
            updateCounts();
        });
    });

    // ── Кнопка «Все присутствуют» ─────────────────────────────────────────────
    var btnAll = document.getElementById('btnAllPresent');
    if (btnAll) {
        btnAll.addEventListener('click', function() {
            document.querySelectorAll('input[name="presentStudents"]').forEach(function(c) { c.checked = true; });
            document.querySelectorAll('input[name="lateStudents"]').forEach(function(c)    { c.checked = false; });
            document.querySelectorAll('input[name="excusedStudents"]').forEach(function(c) { c.checked = false; });
            document.querySelectorAll('#attendanceTable tbody tr').forEach(function(row) {
                var sid = row.id.replace('row-', '');
                updateRow(sid);
            });
            updateCounts();
        });
    }

    // ── Кнопка «Все отсутствуют» ──────────────────────────────────────────────
    var btnAbsent = document.getElementById('btnAllAbsent');
    if (btnAbsent) {
        btnAbsent.addEventListener('click', function() {
            document.querySelectorAll('input[name="presentStudents"]').forEach(function(c) { c.checked = false; });
            document.querySelectorAll('input[name="lateStudents"]').forEach(function(c)    { c.checked = false; });
            document.querySelectorAll('input[name="excusedStudents"]').forEach(function(c) { c.checked = false; });
            document.querySelectorAll('#attendanceTable tbody tr').forEach(function(row) {
                var sid = row.id.replace('row-', '');
                updateRow(sid);
            });
            updateCounts();
        });
    }

    // ── Инициализация счётчиков при загрузке ──────────────────────────────────
    updateCounts();
})();
</script>
}
