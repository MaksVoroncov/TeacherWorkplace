@model TeacherWorkplace.Models.Student
@{ ViewData["Title"] = "Удалить студента"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-user-minus me-2 text-danger"></i>Удалить студента</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Назад</a>
</div>
<div class="card border-danger" style="max-width:500px">
    <div class="card-header bg-danger text-white">Подтверждение удаления</div>
    <div class="card-body">
        <p class="mb-3">Вы действительно хотите удалить студента <strong>@Model.FullName</strong>?</p>
        <dl class="row">
            <dt class="col-5">Группа</dt><dd class="col-7">@Model.Group?.Name</dd>
            <dt class="col-5">Дата рождения</dt><dd class="col-7">@Model.BirthDate.ToString("dd.MM.yyyy")</dd>
        </dl>
        <div class="alert alert-warning">Все оценки и записи посещаемости студента будут удалены.</div>
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>Удалить</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>
