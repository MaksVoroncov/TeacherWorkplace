@model TeacherWorkplace.Models.Grade
@{ ViewData["Title"] = "Удалить оценку"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-trash me-2 text-danger"></i>Удалить оценку</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Назад</a>
</div>
<div class="card border-danger" style="max-width:450px">
    <div class="card-header bg-danger text-white">Подтверждение удаления</div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-5">Студент</dt><dd class="col-7">@Model.Student?.FullName</dd>
            <dt class="col-5">Дисциплина</dt><dd class="col-7">@Model.Subject?.Name</dd>
            <dt class="col-5">Оценка</dt><dd class="col-7"><strong>@Model.Score</strong></dd>
            <dt class="col-5">Дата</dt><dd class="col-7">@Model.Date.ToString("dd.MM.yyyy")</dd>
        </dl>
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>Удалить</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>
