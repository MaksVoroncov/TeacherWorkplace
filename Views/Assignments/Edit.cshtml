@model TeacherWorkplace.Models.Assignment
@{
    ViewData["Title"] = "Редактировать задание";
    var subjectList = ViewData["SubjectId"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-edit me-2 text-warning"></i>Редактировать задание</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Назад</a>
</div>
<div class="card" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold">Название задания</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SubjectId" class="form-label fw-semibold">Дисциплина</label>
                <select asp-for="SubjectId" asp-items="subjectList" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-7">
                    <label asp-for="Deadline" class="form-label fw-semibold">Дедлайн</label>
                    <input asp-for="Deadline" type="datetime-local" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="MaxScore" class="form-label fw-semibold">Макс. балл</label>
                    <input asp-for="MaxScore" type="number" class="form-control" min="1" max="100" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Активно</label>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-warning"><i class="fas fa-save me-1"></i>Сохранить</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
