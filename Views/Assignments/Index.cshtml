@model IEnumerable<TeacherWorkplace.Models.Assignment>
@{ ViewData["Title"] = "Задания"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-tasks me-2 text-info"></i>Задания</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Создать задание</a>
</div>
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <select name="subjectId" class="form-select">
                    <option value="">— Все дисциплины —</option>
                    @foreach (var s in (List<TeacherWorkplace.Models.Subject>)ViewBag.Subjects)
                    {
                        <option value="@s.Id" selected="@(Context.Request.Query["subjectId"] == s.Id.ToString())">@s.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <div class="form-check mt-2">
                    <input type="checkbox" name="activeOnly" value="true" class="form-check-input" id="active"
                           checked="@(Context.Request.Query["activeOnly"] == "true")" />
                    <label class="form-check-label" for="active">Только активные</label>
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-outline-primary w-100"><i class="fas fa-filter me-1"></i>Применить</button>
            </div>
        </form>
    </div>
</div>
<div class="row g-3">
    @foreach (var a in Model)
    {
        bool overdue = a.IsOverdue && a.IsActive;
        <div class="col-md-6">
            <div class="card h-100 @(overdue ? "border-danger" : a.IsActive ? "border-success" : "border-secondary")">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">@a.Title</span>
                    @if (overdue)
                    {
                        <span class="badge bg-danger">Просрочено</span>
                    }
                    else if (a.IsActive)
                    {
                        <span class="badge bg-success">Активно</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Завершено</span>
                    }
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-2">@a.Subject?.Name</p>
                    <p class="mb-1">@a.Description</p>
                    <div class="d-flex gap-3 mt-2">
                        <small class="text-muted"><i class="fas fa-calendar me-1"></i>Дедлайн: <strong>@a.Deadline.ToString("dd.MM.yyyy HH:mm")</strong></small>
                        <small class="text-muted"><i class="fas fa-trophy me-1"></i>Макс. балл: @a.MaxScore</small>
                        <small class="text-muted"><i class="fas fa-check me-1"></i>Сдано: @a.SubmittedCount</small>
                    </div>
                </div>
                <div class="card-footer bg-transparent d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-info"><i class="fas fa-eye me-1"></i>Проверить</a>
                    <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit me-1"></i>Изменить</a>
                </div>
            </div>
        </div>
    }
</div>
