@model TeacherWorkplace.Models.Group
@{ ViewData["Title"] = "Удалить группу"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-trash me-2 text-danger"></i>Удалить группу</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Назад</a>
</div>
<div class="card border-danger" style="max-width:500px">
    <div class="card-header bg-danger text-white">Подтверждение удаления</div>
    <div class="card-body">
        <p>Удалить группу <strong>@Model.Name</strong>?</p>
        <dl class="row">
            <dt class="col-5">Специальность</dt><dd class="col-7">@Model.Specialty</dd>
            <dt class="col-5">Курс</dt><dd class="col-7">@Model.Course</dd>
        </dl>
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>Удалить</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>
