@model TeacherWorkplace.Models.Group
@{ ViewData["Title"] = "Добавить группу"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users me-2 text-success"></i>Добавить группу</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Назад</a>
</div>
<div class="card" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" placeholder="Например: ИСС-241" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Course" class="form-label fw-semibold"></label>
                <input asp-for="Course" type="number" class="form-control" min="1" max="5" />
                <span asp-validation-for="Course" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Specialty" class="form-label fw-semibold"></label>
                <input asp-for="Specialty" class="form-control" />
                <span asp-validation-for="Specialty" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="EnrollmentYear" class="form-label fw-semibold"></label>
                <input asp-for="EnrollmentYear" type="number" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label fw-semibold"></label>
                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Сохранить</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
