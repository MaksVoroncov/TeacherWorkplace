@model TeacherWorkplace.Models.Group
@{ ViewData["Title"] = "Группа " + Model.Name; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users me-2 text-success"></i>Группа @Model.Name</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2"><i class="fas fa-edit me-1"></i>Редактировать</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Назад</a>
    </div>
</div>
<div class="row g-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header"><i class="fas fa-info-circle me-2"></i>Информация</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6">Название</dt><dd class="col-6">@Model.Name</dd>
                    <dt class="col-6">Курс</dt><dd class="col-6">@Model.Course</dd>
                    <dt class="col-6">Специальность</dt><dd class="col-6">@Model.Specialty</dd>
                    <dt class="col-6">Год поступления</dt><dd class="col-6">@Model.EnrollmentYear</dd>
                    <dt class="col-6">Студентов</dt><dd class="col-6"><strong>@Model.StudentsCount</strong></dd>
                    <dt class="col-6">Средний балл</dt><dd class="col-6"><strong>@ViewBag.AverageGrade</strong></dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><i class="fas fa-list me-2"></i>Состав группы</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light"><tr><th>#</th><th>ФИО</th><th>Дата рождения</th><th>Телефон</th></tr></thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var s in Model.Students.OrderBy(x => x.LastName))
                        {
                            <tr>
                                <td>@i</td>
                                <td><a asp-controller="Students" asp-action="Details" asp-route-id="@s.Id">@s.FullName</a></td>
                                <td>@s.BirthDate.ToString("dd.MM.yyyy")</td>
                                <td>@(s.Phone ?? "—")</td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
