@model TeacherWorkplace.Models.Subject
@{ ViewData["Title"] = "Удалить дисциплину"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-trash me-2 text-danger"></i>Удалить дисциплину</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Назад</a>
</div>
<div class="card border-danger" style="max-width:500px">
    <div class="card-header bg-danger text-white">Подтверждение удаления</div>
    <div class="card-body">
        <p>Удалить дисциплину <strong>@Model.Name</strong>?</p>
        <dl class="row">
            <dt class="col-5">Семестр</dt><dd class="col-7">@Model.Semester</dd>
            <dt class="col-5">Часов</dt><dd class="col-7">@Model.TotalHours</dd>
        </dl>
        <div class="alert alert-info small">Дисциплина будет помечена как неактивная (не удалена из БД).</div>
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>Деактивировать</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>
