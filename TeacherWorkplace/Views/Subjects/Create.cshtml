@model TeacherWorkplace.Models.Subject
@{ ViewData["Title"] = "Добавить дисциплину"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-book me-2 text-warning"></i>Добавить дисциплину</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Назад</a>
</div>
<div class="card" style="max-width:550px">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label asp-for="Code" class="form-label fw-semibold"></label>
                    <input asp-for="Code" class="form-control" placeholder="ПМ.01" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Semester" class="form-label fw-semibold"></label>
                    <input asp-for="Semester" type="number" class="form-control" min="1" max="8" />
                    <span asp-validation-for="Semester" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="TotalHours" class="form-label fw-semibold"></label>
                    <input asp-for="TotalHours" type="number" class="form-control" min="1" />
                    <span asp-validation-for="TotalHours" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Сохранить</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
