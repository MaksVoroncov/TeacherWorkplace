@model TeacherWorkplace.Models.Grade
@{
    ViewData["Title"] = "Редактировать оценку";
    var studentList = ViewData["StudentId"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var subjectList = ViewData["SubjectId"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-edit me-2 text-warning"></i>Редактировать оценку</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Назад</a>
</div>
<div class="card" style="max-width:580px">
    <div class="card-body">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label asp-for="StudentId" class="form-label fw-semibold">Студент</label>
                <select asp-for="StudentId" asp-items="studentList" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="SubjectId" class="form-label fw-semibold">Дисциплина</label>
                <select asp-for="SubjectId" asp-items="subjectList" class="form-select"></select>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label asp-for="Score" class="form-label fw-semibold">Оценка</label>
                    <input asp-for="Score" type="number" class="form-control" min="1" max="5" />
                </div>
                <div class="col-md-5">
                    <label asp-for="Type" class="form-label fw-semibold">Тип</label>
                    <select asp-for="Type" class="form-select">
                        <option value="0">Текущая</option>
                        <option value="1">Контрольная работа</option>
                        <option value="2">Лабораторная работа</option>
                        <option value="3">Практическая работа</option>
                        <option value="4">Зачёт</option>
                        <option value="5">Экзамен</option>
                        <option value="6">Итоговая</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Weight" class="form-label fw-semibold">Вес</label>
                    <input asp-for="Weight" type="number" class="form-control" min="1" max="10" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Date" class="form-label fw-semibold">Дата</label>
                <input asp-for="Date" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Описание</label>
                <input asp-for="Description" class="form-control" />
            </div>
            <button type="submit" class="btn btn-warning"><i class="fas fa-save me-1"></i>Сохранить</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Отмена</a>
        </form>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
