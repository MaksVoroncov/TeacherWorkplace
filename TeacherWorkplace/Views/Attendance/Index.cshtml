@model IEnumerable<TeacherWorkplace.Models.Attendance>
@{
    ViewData["Title"] = "Посещаемость";
    var selectedDate = (DateTime)ViewBag.SelectedDate;
    var subjects = (List<TeacherWorkplace.Models.Subject>)ViewBag.Subjects;

    int total   = Model.Count();
    int present = Model.Count(a => a.Status == TeacherWorkplace.Models.AttendanceStatus.Present);
    int absent  = Model.Count(a => a.Status == TeacherWorkplace.Models.AttendanceStatus.Absent);
    int late    = Model.Count(a => a.Status == TeacherWorkplace.Models.AttendanceStatus.Late);
    int excused = Model.Count(a => a.Status == TeacherWorkplace.Models.AttendanceStatus.Excused);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-clipboard-check me-2 text-primary"></i>Посещаемость</h2>
    <a asp-action="TakeAttendance" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> Отметить посещаемость
    </a>
</div>

@* Фильтры *@
<div class="card mb-4">
    <div class="card-header">
        <i class="fas fa-filter me-2"></i> Фильтр
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Дата занятия</label>
                <input type="date" name="date" class="form-control"
                       value="@selectedDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-5">
                <label class="form-label fw-semibold">Дисциплина</label>
                <select name="subjectId" class="form-select">
                    <option value="">— Все дисциплины —</option>
                    @foreach (var s in subjects)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search me-1"></i> Применить
                </button>
            </div>
        </form>
    </div>
</div>

@* Сводная статистика *@
@if (total > 0)
{
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card stat-card border-start border-primary border-4 shadow-sm">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small">Всего записей</div>
                            <div class="fs-3 fw-bold text-primary">@total</div>
                        </div>
                        <i class="fas fa-users fa-2x text-primary opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-start border-success border-4 shadow-sm">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small">Присутствовали</div>
                            <div class="fs-3 fw-bold text-success">@present</div>
                        </div>
                        <i class="fas fa-check-circle fa-2x text-success opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-start border-danger border-4 shadow-sm">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small">Отсутствовали</div>
                            <div class="fs-3 fw-bold text-danger">@absent</div>
                        </div>
                        <i class="fas fa-times-circle fa-2x text-danger opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-start border-warning border-4 shadow-sm">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small">Опоздали / Уваж.</div>
                            <div class="fs-3 fw-bold text-warning">@(late + excused)</div>
                        </div>
                        <i class="fas fa-clock fa-2x text-warning opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* Таблица записей *@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="fas fa-list me-2"></i>
            Записи за <strong>@selectedDate.ToString("dd.MM.yyyy")</strong>
            — найдено: <strong>@total</strong>
        </span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-clipboard fa-3x mb-3 d-block opacity-25"></i>
                <h5>Записей посещаемости за эту дату нет</h5>
                <p class="mb-3">Нажмите кнопку ниже, чтобы отметить посещаемость на занятии.</p>
                <a asp-action="TakeAttendance" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i> Отметить посещаемость
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th><i class="fas fa-user me-1"></i>Студент</th>
                            <th><i class="fas fa-users me-1"></i>Группа</th>
                            <th><i class="fas fa-book me-1"></i>Дисциплина</th>
                            <th><i class="fas fa-calendar me-1"></i>Дата</th>
                            <th><i class="fas fa-info-circle me-1"></i>Статус</th>
                            <th>Примечания</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var item in Model.OrderBy(a => a.Student?.LastName))
                        {
                            <tr>
                                <td class="text-muted">@i</td>
                                <td>
                                    <div class="fw-semibold">@item.Student?.FullName</div>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@item.Student?.Group?.Name</span>
                                </td>
                                <td>@item.Subject?.Name</td>
                                <td>@item.Date.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case TeacherWorkplace.Models.AttendanceStatus.Present:
                                            <span class="badge bg-success">
                                                <i class="fas fa-check me-1"></i>Присутствовал
                                            </span>
                                            break;
                                        case TeacherWorkplace.Models.AttendanceStatus.Absent:
                                            <span class="badge bg-danger">
                                                <i class="fas fa-times me-1"></i>Отсутствовал
                                            </span>
                                            break;
                                        case TeacherWorkplace.Models.AttendanceStatus.Late:
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-clock me-1"></i>Опоздал
                                            </span>
                                            break;
                                        case TeacherWorkplace.Models.AttendanceStatus.Excused:
                                            <span class="badge bg-info text-dark">
                                                <i class="fas fa-file-alt me-1"></i>Уваж. причина
                                            </span>
                                            break;
                                    }
                                </td>
                                <td class="text-muted small">@(item.Notes ?? "—")</td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
