@{
    ViewData["Title"] = "Главная панель";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-home"></i> Главная панель</h2>
    <span class="text-muted">@DateTime.Now.ToString("dd MMMM yyyy, HH:mm")</span>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stat-card students">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-2">Студенты</h6>
                        <h2 class="mb-0">@ViewBag.TotalStudents</h2>
                    </div>
                    <i class="fas fa-user-graduate fa-3x text-primary opacity-25"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card stat-card groups">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-2">Группы</h6>
                        <h2 class="mb-0">@ViewBag.TotalGroups</h2>
                    </div>
                    <i class="fas fa-users fa-3x text-success opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card stat-card subjects">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-2">Дисциплины</h6>
                        <h2 class="mb-0">@ViewBag.TotalSubjects</h2>
                    </div>
                    <i class="fas fa-book fa-3x text-warning opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card stat-card assignments">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-2">Непроверенные</h6>
                        <h2 class="mb-0">@ViewBag.PendingAssignments</h2>
                    </div>
                    <i class="fas fa-tasks fa-3x text-danger opacity-25"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-info-circle"></i> Статистика
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-md-6">
                        <h5>Средний балл</h5>
                        <h2 class="text-success">@ViewBag.AverageGrade</h2>
                    </div>
                    <div class="col-md-6">
                        <h5>Посещений сегодня</h5>
                        <h2 class="text-primary">@ViewBag.TodayAttendance</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-user-plus"></i> Недавно добавленные студенты
            </div>
            <div class="card-body">
                @if (ViewBag.RecentStudents != null && ViewBag.RecentStudents.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <tbody>
                                @foreach (var student in ViewBag.RecentStudents)
                                {
                                    <tr>
                                        <td>@student.FullName</td>
                                        <td>@student.Group.Name</td>
                                        <td class="text-muted">@student.EnrollmentDate.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center">Нет данных</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-clock"></i> Ближайшие дедлайны заданий
            </div>
            <div class="card-body">
                @if (ViewBag.UpcomingDeadlines != null && ViewBag.UpcomingDeadlines.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <tbody>
                                @foreach (var assignment in ViewBag.UpcomingDeadlines)
                                {
                                    <tr>
                                        <td>@assignment.Title</td>
                                        <td>@assignment.Subject.Name</td>
                                        <td class="text-danger">@assignment.Deadline.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center">Нет активных заданий</p>
                }
            </div>
        </div>
    </div>
</div>
