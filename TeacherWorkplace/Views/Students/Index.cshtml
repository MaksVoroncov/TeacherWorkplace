@model IEnumerable<TeacherWorkplace.Models.Student>
@{ ViewData["Title"] = "Студенты"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-user-graduate me-2 text-primary"></i>Студенты</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Добавить студента</a>
</div>
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <input type="text" name="search" class="form-control" placeholder="Поиск по фамилии или имени..." value="@Context.Request.Query["search"]" />
            </div>
            <div class="col-md-4">
                <select name="groupId" class="form-select">
                    <option value="">— Все группы —</option>
                    @foreach (var g in (List<TeacherWorkplace.Models.Group>)ViewBag.Groups)
                    {
                        <option value="@g.Id" selected="@(Context.Request.Query["groupId"] == g.Id.ToString())">@g.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-primary w-100"><i class="fas fa-search me-1"></i>Найти</button>
            </div>
        </form>
    </div>
</div>
<div class="card">
    <div class="card-header"><i class="fas fa-list me-2"></i>Список студентов — <strong>@Model.Count()</strong></div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-user-slash fa-3x mb-3 d-block opacity-25"></i>
                <h5>Студентов не найдено</h5>
                <a asp-action="Create" class="btn btn-primary mt-2"><i class="fas fa-plus me-1"></i>Добавить первого студента</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px">#</th>
                            <th>ФИО</th>
                            <th>Группа</th>
                            <th>Дата рождения</th>
                            <th>Телефон</th>
                            <th>Email</th>
                            <th style="width:130px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="text-muted">@i</td>
                                <td><span class="fw-semibold">@s.FullName</span></td>
                                <td><span class="badge bg-secondary">@s.Group?.Name</span></td>
                                <td>@s.BirthDate.ToString("dd.MM.yyyy")</td>
                                <td>@(s.Phone ?? "—")</td>
                                <td>@(s.Email ?? "—")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-info me-1" title="Подробнее"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-warning me-1" title="Редактировать"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-sm btn-outline-danger" title="Удалить"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
