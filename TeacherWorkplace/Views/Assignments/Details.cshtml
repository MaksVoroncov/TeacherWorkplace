@model TeacherWorkplace.Models.Assignment
@{ ViewData["Title"] = "Проверка заданий: " + Model.Title; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-clipboard-check me-2 text-info"></i>@Model.Title</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2"><i class="fas fa-edit me-1"></i>Редактировать</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Назад</a>
    </div>
</div>
<div class="row g-4">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header">Информация о задании</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-6">Дисциплина</dt><dd class="col-6">@Model.Subject?.Name</dd>
                    <dt class="col-6">Дедлайн</dt><dd class="col-6 @(Model.IsOverdue ? "text-danger fw-bold" : "")">@Model.Deadline.ToString("dd.MM.yyyy HH:mm")</dd>
                    <dt class="col-6">Макс. балл</dt><dd class="col-6">@Model.MaxScore</dd>
                    <dt class="col-6">Сдано работ</dt><dd class="col-6">@Model.SubmittedCount</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">Сдача работ студентами</div>
            <div class="card-body p-0">
                @if (!Model.StudentAssignments.Any())
                {
                    <p class="text-muted text-center py-4">Работ пока не сдано</p>
                }
                else
                {
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr><th>Студент</th><th>Группа</th><th>Статус</th><th>Балл</th><th>Дата сдачи</th><th>Действие</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var sa in Model.StudentAssignments.OrderBy(x => x.Student?.LastName))
                            {
                                <tr>
                                    <td>@sa.Student?.FullName</td>
                                    <td><span class="badge bg-secondary">@sa.Student?.Group?.Name</span></td>
                                    <td>
                                        @switch (sa.Status)
                                        {
                                            case TeacherWorkplace.Models.AssignmentStatus.Submitted:
                                                <span class="badge bg-warning text-dark">Сдано</span>
                                                break;
                                            case TeacherWorkplace.Models.AssignmentStatus.Graded:
                                                <span class="badge bg-success">Оценено</span>
                                                break;
                                            case TeacherWorkplace.Models.AssignmentStatus.InProgress:
                                                <span class="badge bg-info text-dark">В работе</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@sa.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td>@(sa.Score?.ToString() ?? "—")</td>
                                    <td>@(sa.SubmittedDate?.ToString("dd.MM.yy HH:mm") ?? "—")</td>
                                    <td>
                                        @if (sa.Status == TeacherWorkplace.Models.AssignmentStatus.Submitted)
                                        {
                                            <form asp-action="GradeSubmission" method="post" class="d-flex gap-1">
                                                <input type="hidden" name="studentAssignmentId" value="@sa.Id" />
                                                <input type="number" name="score" class="form-control form-control-sm" style="width:70px" min="0" max="@Model.MaxScore" placeholder="Балл" />
                                                <button type="submit" class="btn btn-sm btn-success">OK</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
